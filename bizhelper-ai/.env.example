# ──────────────────────────────────────────────────────────────
# BizHelper AI — environment variables
# Copy this file to ".env.local" and fill in your keys.
# The marketing site + demo work WITHOUT any keys.
# Auth, the dashboard, and billing turn on once the relevant keys are set.
# ──────────────────────────────────────────────────────────────

# ── Public site URL (used for SEO + auth email redirect links) ──
# Local: http://localhost:3000   |   Production: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI provider for /api/generate: "mock" | "openai" | "gemini" ──
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────────────────
# Supabase (Auth + Database)
# Project → Settings → API. URL + anon key are safe for the browser.
# The service role key is SECRET — server-side only, never exposed.
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth vars — NOT required (this project uses Supabase Auth).
# Kept here only if you later swap in Auth.js. Leave blank otherwise.
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ──────────────────────────────────────────────────────────────
# PayPal (monthly subscriptions)
# Only NEXT_PUBLIC_PAYPAL_CLIENT_ID reaches the browser. The rest are SECRET.
# Set PAYPAL_ENV=live for production; "sandbox" is the default for testing.
# ──────────────────────────────────────────────────────────────
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# PayPal Plan IDs — create a product + monthly plans in the PayPal dashboard,
# then paste each plan's ID here (these are public identifiers, not secrets).
PAYPAL_BASIC_PLAN_ID=
PAYPAL_PRO_PLAN_ID=
PAYPAL_BUSINESS_PLAN_ID=
